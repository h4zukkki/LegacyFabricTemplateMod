{
  "schemaVersion": 1,
  "id": "modid",
  "version": "${mod_version}",
  "name": "Example Mod",
  "description": "This is an example description! Tell everyone what your mod is about!",
  "authors": [
    "Me!"
  ],
  "contact": {
    "homepage": "https://legacyfabric.net/",
    "sources": "https://github.com/Legacy-Fabric/fabric-example-mod"
  },
  "license": "MIT",
  "icon": "assets/modid/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "net.legacyfabric.example.ExampleMod"
      }
    ]
  },
  "mixins": [
    "modid-1.mixins.json",
    "modid-2.mixins.json"
  ],
  "depends": {
    "minecraft": "~${minecraft_version}",
    "fabricloader": ">=${fabricLoader_version}",
    "legacy-fabric-api": ">=${legacyFabricApi_version}",
    "fabric-language-kotlin": ">=${fabricLanguageKotlin_version}"
  }
}
